<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/flux_background">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/flux_card"
            android:elevation="4dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:titleTextColor="@color/flux_neon_blue"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/layoutCurrentNetwork"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnScan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/scan"
                        android:backgroundTint="@color/flux_neon_blue"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/save"
                        android:backgroundTint="@color/flux_neon_green"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:enabled="false"/>
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerCurrent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:id="@+id/progressContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:background="@drawable/dialog_background"
                        android:elevation="8dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:indeterminateTint="@color/flux_neon_blue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/scanning"
                            android:textColor="@color/flux_neon_blue"
                            android:textStyle="bold" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSavedNetworks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/flux_neon_blue"
                    android:layout_marginBottom="16dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerSaved"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:id="@+id/txtNoSaved"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_saved_networks"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:visibility="gone"/>
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/layoutSetupGuide"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fluxio Setup Guide"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/flux_neon_blue"
                        android:layout_marginBottom="16dp" />

                    <!-- Step 1 Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/flux_card"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="@color/flux_neon_green"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Step 1: Connect to Local Network"
                                android:textStyle="bold"
                                android:textColor="@color/flux_neon_green"
                                android:textSize="18sp"
                                android:layout_marginBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ensure your Android device is connected to the same Wi-Fi network as the computers you wish to manage."
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Step 2 Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/flux_card"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="@color/flux_neon_green"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Step 2: Scan for Devices"
                                android:textStyle="bold"
                                android:textColor="@color/flux_neon_green"
                                android:textSize="18sp"
                                android:layout_marginBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tap the Scan button on the main screen to discover devices in your local network."
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Step 3 Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/flux_card"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="@color/flux_neon_green"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Step 3: Save to Cloud"
                                android:textStyle="bold"
                                android:textColor="@color/flux_neon_green"
                                android:textSize="18sp"
                                android:layout_marginBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tap Save to register discovered devices in Supabase for remote management."
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Step 4 Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/flux_card"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="@color/flux_neon_green"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Step 4: BIOS Configuration"
                                android:textStyle="bold"
                                android:textColor="@color/flux_neon_green"
                                android:textSize="18sp"
                                android:layout_marginBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Enable Wake-on-LAN in your computer's BIOS/UEFI settings (Power Management -> PCI-E Wake)."
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Step 5 Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/flux_card"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="@color/flux_neon_blue"
                        app:strokeWidth="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Step 5: Run Deployment Script"
                                android:textStyle="bold"
                                android:textColor="@color/flux_neon_blue"
                                android:textSize="18sp"
                                android:layout_marginBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Deploy the agent script on your PC to link it with the cloud database."
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="16dp" />

                            <!-- Windows -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <Button
                                    android:id="@+id/btnCopyWindowsScript"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Windows Command"
                                    android:textColor="@color/text_primary"
                                    app:icon="@drawable/computer"
                                    app:iconTint="@color/flux_neon_blue" />
                                <ImageButton
                                    android:id="@+id/btnShareWin"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_menu_share"
                                    app:tint="@color/flux_neon_blue" />
                            </LinearLayout>

                            <!-- Linux -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <Button
                                    android:id="@+id/btnCopyLinuxScript"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Linux Command"
                                    android:textColor="@color/text_primary"
                                    app:icon="@drawable/computer"
                                    app:iconTint="@color/flux_neon_blue" />
                                <ImageButton
                                    android:id="@+id/btnShareLinux"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_menu_share"
                                    app:tint="@color/flux_neon_blue" />
                            </LinearLayout>

                            <!-- macOS -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <Button
                                    android:id="@+id/btnCopyMacScript"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="macOS Command"
                                    android:textColor="@color/text_primary"
                                    app:icon="@drawable/computer"
                                    app:iconTint="@color/flux_neon_blue" />
                                <ImageButton
                                    android:id="@+id/btnShareMac"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_menu_share"
                                    app:tint="@color/flux_neon_blue" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Step 6 Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:cardBackgroundColor="@color/flux_card"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="@color/flux_neon_green"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Step 6: Remote Control"
                                android:textStyle="bold"
                                android:textColor="@color/flux_neon_green"
                                android:textSize="18sp"
                                android:layout_marginBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="You're all set! Control your devices from anywhere via the cloud status monitoring."
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <Button
                        android:id="@+id/btnFinishSetup"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="GET STARTED"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/flux_neon_blue"
                        android:textColor="@color/black"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/flux_card"
        app:itemTextColor="@color/text_primary"
        app:itemIconTint="@color/flux_neon_blue"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>